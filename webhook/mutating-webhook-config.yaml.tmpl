# MutatingWebhookConfiguration for the EoB pod webhook.
# Substitute __HOST_IP__, __PORT__ and __CA_B64__ before applying.
# The install.sh in this directory does the substitution and kubectl apply.
apiVersion: admissionregistration.k8s.io/v1
kind: MutatingWebhookConfiguration
metadata:
  name: eob-mutate
webhooks:
  - name: eob-mutate.f5.local
    admissionReviewVersions: ["v1"]
    sideEffects: None
    failurePolicy: Fail
    timeoutSeconds: 5
    # IfNeeded: if a later webhook in the chain mutates the spec we
    # care about (hostNetwork, hostAliases, container ports), the
    # apiserver re-invokes us so our patches stay coherent.
    reinvocationPolicy: IfNeeded
    clientConfig:
      # URL form (not Service form) because the webhook server runs as a systemd
      # service on the master-0 host, not as a k8s pod.
      url: https://__HOST_IP__:__PORT__/mutate
      caBundle: __CA_B64__
    rules:
      - operations: ["CREATE"]
        apiGroups: [""]
        apiVersions: ["v1"]
        resources: ["pods"]
        scope: Namespaced
    # Namespace gate only. There is no objectSelector — server.py
    # decides per pod whether to mutate (name-prefix match against
    # tawon-directive / tawon-dashboard / tawon-streamstore) and
    # returns an empty patch for everything else. This covers the
    # three pod families the chart renders with chart-generated label
    # suffixes (e.g. tawon-streamstore-d2f18e) that an objectSelector
    # cannot match across reinstalls.
    namespaceSelector:
      matchLabels:
        kubernetes.io/metadata.name: tawon-operator
